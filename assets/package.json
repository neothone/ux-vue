{
    "name": "@symfony/ux-vue",
    "description": "Integration of Vue.js in Symfony",
    "license": "MIT",
    "version": "2.27.0",
    "keywords": [
        "symfony-ux"
    ],
    "homepage": "https://ux.symfony.com/vue",
    "repository": "https://github.com/symfony/ux-vue",
    "type": "module",
    "files": [
        "dist"
    ],
    "main": "dist/register_controller.js",
    "types": "dist/register_controller.d.ts",
    "scripts": {
        "build": "tsx ../../../bin/build_package.ts .",
        "watch": "tsx ../../../bin/build_package.ts . --watch",
        "test": "../../../bin/test_package.sh .",
        "check": "biome check",
        "ci": "biome ci"
    },
    "symfony": {
        "controllers": {
            "vue": {
                "main": "dist/render_controller.js",
                "webpackMode": "eager",
                "fetch": "eager",
                "enabled": true
            }
        },
        "importmap": {
            "@hotwired/stimulus": "^3.0.0",
            "vue": {
                "package": "vue/dist/vue.esm-bundler.js",
                "version": "^3.0"
            },
            "@symfony/ux-vue": "path:%PACKAGE%/dist/loader.js"
        }
    },
    "peerDependencies": {
        "@hotwired/stimulus": "^3.0.0",
        "vue": "^3.0"
    },
    "devDependencies": {
        "@hotwired/stimulus": "^3.0.0",
        "@testing-library/dom": "catalog:",
        "@testing-library/jest-dom": "catalog:",
        "@testing-library/user-event": "catalog:",
        "@types/webpack-env": "^1.16",
        "@vitejs/plugin-vue": "^4.4.0",
        "jsdom": "catalog:",
        "tslib": "catalog:",
        "tsx": "catalog:",
        "typescript": "catalog:",
        "vitest": "catalog:",
        "vue": "^3.0"
    }
}
